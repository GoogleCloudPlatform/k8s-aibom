      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Total Config Reloads",
      "targets": [
        { "expr": "sum(aibom_controller_config_reloads_total)" }
      ],
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Sink Emit Failures",
      "targets": [
        { "expr": "sum(aibom_external_sink_emit_failures_total)" }
      ],
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 }
    },
    {
      "type": "stat",
      "title": "GCS Write Failures",
      "targets": [
        { "expr": "sum(aibom_external_sink_emit_failures_total{sink=\"gcs\"})" }
      ],
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Webhook Write Failures",
      "targets": [
        { "expr": "sum(aibom_external_sink_emit_failures_total{sink=\"webhook\"})" }
      ],
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Sink Failures Over Time (by Sink)",
      "targets": [
        { "expr": "rate(aibom_external_sink_emit_failures_total[5m])", "legendFormat": "{{sink}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }
    },
    {
      "type": "timeseries",
      "title": "Scraper Extraction Errors (by Scraper)",
      "targets": [
        { "expr": "rate(aibom_scraper_extraction_errors_total[5m])", "legendFormat": "{{scraper}} - {{evidence_source}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }
    }
  ],
